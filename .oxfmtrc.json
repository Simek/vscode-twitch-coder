{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "singleQuote": true,
  "bracketSameLine": true,
  "trailingComma": "es5",
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "ignorePatterns": [".idea", ".vscode-test", "node_modules", "out", "tests-out", "*.vsix", "package.json"],
  "sortPackageJson": false,
  "sortImports": {
    "groups": [["side_effect"], ["builtin", "external"], ["internal"], ["parent"], ["sibling"], ["index"]]
  }
}
